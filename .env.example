# ═══════════════════════════════════════════════════════════════════
# SAL Hub — variáveis de ambiente
#
# Copie este arquivo para .env e preencha os valores.
# Para VPS: o script scripts/setup-vps.sh cria o .env automaticamente.
# ═══════════════════════════════════════════════════════════════════

# ─── Banco de dados ────────────────────────────────────────────────
# Em produção, use uma senha forte. Gere com: openssl rand -base64 18
POSTGRES_USER=sal
POSTGRES_PASSWORD=troque_essa_senha
POSTGRES_DB=salhub

# Para Docker (compose interno): host = "db" (nome do serviço)
DATABASE_URL="postgresql://sal:troque_essa_senha@db:5432/salhub?schema=public"
# Para dev local apontando ao container: host = "localhost"
# DATABASE_URL="postgresql://sal:troque_essa_senha@localhost:5432/salhub?schema=public"

# ─── NextAuth (autenticação) ───────────────────────────────────────
# OBRIGATÓRIO em produção. Gere com: openssl rand -base64 32
NEXTAUTH_SECRET="GERAR_UMA_STRING_LONGA_E_ALEATORIA_AQUI"

# URL pública do app — não termine com /
# Dev local:
NEXTAUTH_URL="http://localhost:3000"
# Produção:
# NEXTAUTH_URL="https://hub.sal.com.br"

# ─── Google OAuth (Drive + Calendar) ───────────────────────────────
# Crie no console.cloud.google.com → Credentials → OAuth 2.0 Client ID
# Authorized redirect URIs: <NEXTAUTH_URL>/api/auth/callback/google
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ─── Onboarding automático de cliente — destino no Drive ──────────
# Define onde as pastas dos clientes novos são criadas.
#
# Opção 1 (recomendada): auto-detect por nome de Shared Drive.
# Se você tem um Drive Compartilhado chamado "Clientes SAL", o sistema
# acha sozinho — não precisa configurar nada. Pra usar outro nome:
# ONBOARDING_DRIVE_NAME="Clientes SAL"
#
# Opção 2: ID direto de pasta ou Shared Drive (bypass do lookup por nome).
# Use isso pra criar dentro de uma subpasta tipo "Clientes SAL/2026/".
# ID da pasta = parte final da URL `https://drive.google.com/drive/folders/XXX`
# ONBOARDING_DRIVE_PARENT_ID=""
#
# Sem nenhuma das duas: cria em "Meu Drive" pessoal do usuário logado.

# ─── Misc ──────────────────────────────────────────────────────────
NODE_ENV="development"
TZ="America/Sao_Paulo"

# ─── Emails transacionais (Resend) ─────────────────────────────────
# OPCIONAL. Sem isso, sininho continua funcionando, mas sem email.
#
# Setup:
#  1. Criar conta em resend.com (free: 100 emails/dia, 3000/mês)
#  2. Adicionar domínio em Domains → Add Domain (ex: salestrategias.com.br)
#  3. Adicionar os 4 DNS records do Resend no provedor (Cloudflare,
#     Registro.br, etc) e aguardar verificação (~10min)
#  4. Criar API Key em API Keys → Create — copiar e colar abaixo
#  5. Setar MAIL_FROM com email no domínio verificado
#  6. Restartar container
# RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxx"
# MAIL_FROM="SAL Hub <notificacoes@salestrategias.com.br>"
# NEXT_PUBLIC_HUB_URL="https://hub.salestrategias.com.br"

# ─── Backup off-site para S3 (OPCIONAL) ───────────────────────────
# Descomente e preencha para ativar upload automático após cada backup local.
# AWS_ACCESS_KEY_ID=""
# AWS_SECRET_ACCESS_KEY=""
# AWS_DEFAULT_REGION="us-east-1"
# S3_BUCKET="sal-hub-backups"
# S3_PREFIX="daily"
# Para Backblaze B2 / Wasabi / Cloudflare R2:
# S3_ENDPOINT="https://s3.us-west-002.backblazeb2.com"

# ─── Backups locais (OPCIONAL) ────────────────────────────────────
# BACKUP_DIR="/opt/sal-hub/backups"  (default)
# BACKUP_KEEP=30                      (quantos manter)
