// =====================================================================
// SAL Hub — Schema Prisma completo
// =====================================================================
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────────────
// Auth (NextAuth v5 + credenciais + tokens Google)
// ─────────────────────────────────────────────────────────────────────
model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?   @db.Text   // dataURL (avatar comprimido) ou URL externa
  passwordHash  String?
  role          UserRole  @default(MEMBER)

  // Tokens Google (para Drive + Calendar)
  googleAccessToken      String?  @db.Text
  googleRefreshToken     String?  @db.Text
  googleTokenExpiresAt   DateTime?
  googleScope            String?  @db.Text

  accounts      Account[]
  sessions      Session[]
  atividades    AtividadeConta[]
  notificacoes  Notificacao[]
  propostas     Proposta[]
  shares        PublicShare[]
  leads         Lead[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum UserRole {
  ADMIN
  MEMBER
}

// ─────────────────────────────────────────────────────────────────────
// Logs de atividade da conta — rastreia logins, mudanças de senha, tokens MCP
// ─────────────────────────────────────────────────────────────────────
model AtividadeConta {
  id        String        @id @default(cuid())
  tipo      TipoAtividade
  ip        String?
  userAgent String?       @db.Text
  meta      Json?         // contexto adicional (provider, nome do token, escopos, etc.)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([userId, createdAt(sort: Desc)])
  @@index([tipo])
}

enum TipoAtividade {
  LOGIN_OK
  LOGIN_FALHOU
  MUDANCA_SENHA
  MUDANCA_PERFIL
  TOKEN_MCP_CRIADO
  TOKEN_MCP_REVOGADO
  TOKEN_MCP_ESCOPOS_ALTERADOS
  GOOGLE_CONECTADO
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime
  @@unique([identifier, token])
}

// ─────────────────────────────────────────────────────────────────────
// CRM
// ─────────────────────────────────────────────────────────────────────
model Cliente {
  id                    String         @id @default(cuid())
  nome                  String
  cnpj                  String?
  email                 String?
  telefone              String?
  endereco              String?
  status                ClienteStatus  @default(ATIVO)
  valorContratoMensal   Decimal        @default(0) @db.Decimal(12, 2)
  notas                 String?        @db.Text

  // Integração Drive
  googleDriveFolderId   String?
  googleDriveFolderUrl  String?

  // Onboarding automático — marcado depois que pasta Drive + projeto
  // Onboarding + tarefas iniciais foram criados pra esse cliente.
  // Idempotência: triggers verificam se != null antes de re-executar.
  onboardingFeitoEm     DateTime?

  posts        Post[]
  projetos     Projeto[]
  tarefas      Tarefa[]
  contratos    Contrato[]
  lancamentos  Lancamento[]
  arquivos     DriveArquivo[]
  metricasRede MetricaRede[]
  keywords     SeoKeyword[]
  metricasSeo  MetricaSeo[]
  campanhas    CampanhaPaga[]
  metasRede    MetaRede[]
  tags         Tag[]          @relation("ClienteTags")
  reunioes     Reuniao[]
  propostas    Proposta[]
  lead         Lead?          // lead que virou esse cliente (relação reversa 1:1)
  integracoesSheets IntegracaoSheets[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum ClienteStatus {
  ATIVO
  INATIVO
  PROSPECT
  CHURNED
}

// ─────────────────────────────────────────────────────────────────────
// Tags livres para clientes (M2M) — independente do enum status
// Exemplos: "Cliente Ativo", "Cliente Desativado", "Em Onboarding", "VIP"
// ─────────────────────────────────────────────────────────────────────
model Tag {
  id        String    @id @default(cuid())
  nome      String    @unique
  cor       String    @default("#7E30E1") // hex — paleta SAL
  clientes  Cliente[] @relation("ClienteTags")
  createdAt DateTime  @default(now())
}

// ─────────────────────────────────────────────────────────────────────
// Workspace — Reuniões com transcrição estilo Notion
// ─────────────────────────────────────────────────────────────────────
model Reuniao {
  id            String         @id @default(cuid())
  titulo        String
  data          DateTime
  duracaoSeg    Int?           // duração em segundos
  audioUrl      String?        @db.Text
  resumoIA      String?        @db.Text
  notasLivres   String?        @db.Text
  status        ReuniaoStatus  @default(GRAVADA)
  participantes String[]       // array PG nativo
  tagsLivres    String[]

  clienteId String?
  cliente   Cliente? @relation(fields: [clienteId], references: [id], onDelete: SetNull)

  blocks      ReuniaoBlock[]
  actionItems ReuniaoAction[]
  capitulos   ReuniaoCapitulo[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([data])
  @@index([clienteId])
}

enum ReuniaoStatus {
  GRAVANDO
  PROCESSANDO
  TRANSCRITA
  GRAVADA
}

model ReuniaoBlock {
  id         String  @id @default(cuid())
  ordem      Int     @default(0)
  timestamp  Int     // segundos desde início
  speaker    String
  speakerCor String?
  texto      String  @db.Text

  reuniaoId String
  reuniao   Reuniao @relation(fields: [reuniaoId], references: [id], onDelete: Cascade)

  @@index([reuniaoId, ordem])
}

model ReuniaoAction {
  id          String   @id @default(cuid())
  ordem       Int      @default(0)
  texto       String
  responsavel String?
  prazo       String?
  concluido   Boolean  @default(false)

  reuniaoId String
  reuniao   Reuniao @relation(fields: [reuniaoId], references: [id], onDelete: Cascade)
}

model ReuniaoCapitulo {
  id        String  @id @default(cuid())
  ordem     Int     @default(0)
  timestamp Int
  titulo    String

  reuniaoId String
  reuniao   Reuniao @relation(fields: [reuniaoId], references: [id], onDelete: Cascade)
}

// ─────────────────────────────────────────────────────────────────────
// Workspace — Notas estilo Obsidian (markdown + tags + pasta)
// ─────────────────────────────────────────────────────────────────────
model Nota {
  id        String   @id @default(cuid())
  titulo    String
  pasta     String   @default("Inbox")
  conteudo  String   @default("") @db.Text
  tags      String[]
  favorita  Boolean  @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([pasta])
  @@index([titulo])
}

// ─────────────────────────────────────────────────────────────────────
// Workspace — Mapas Mentais (Excalidraw-like; estado serializado em JSON)
// ─────────────────────────────────────────────────────────────────────
model MindMap {
  id          String   @id @default(cuid())
  titulo      String
  descricao   String?
  data        Json     // { nodes: [...], edges: [...] }
  thumbnail   String?  @db.Text  // dataURL opcional para preview

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─────────────────────────────────────────────────────────────────────
// MCP — Tokens para Claude Desktop/Code via Model Context Protocol
// Cada token autentica uma instância de Claude conectada ao SAL Hub.
// ─────────────────────────────────────────────────────────────────────
model McpToken {
  id          String    @id @default(cuid())
  nome        String                          // ex: "Claude Desktop pessoal"
  hash        String    @unique               // SHA-256 do token (nunca persistimos o token bruto)
  prefixo     String                          // primeiros 16 chars visíveis na UI (ex: "salhub_a1b2...")
  ultimoUso   DateTime?
  expiraEm    DateTime?
  revogadoEm  DateTime?
  escopos     String[]  @default([])          // futuro: limitar tools por token
  totalChamadas Int     @default(0)

  createdAt DateTime @default(now())

  @@index([hash])
}

// ─────────────────────────────────────────────────────────────────────
// Calendário Editorial
// ─────────────────────────────────────────────────────────────────────
model Post {
  id              String      @id @default(cuid())
  titulo          String
  legenda         String?     @db.Text
  pilar           String?
  formato         PostFormato @default(FEED)
  status          PostStatus  @default(RASCUNHO)
  dataPublicacao  DateTime
  googleEventId   String?

  clienteId String
  cliente   Cliente @relation(fields: [clienteId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([dataPublicacao])
  @@index([clienteId])
}

enum PostFormato {
  FEED
  STORIES
  REELS
  CARROSSEL
}

enum PostStatus {
  RASCUNHO
  COPY_PRONTA
  DESIGN_PRONTO
  AGENDADO
  PUBLICADO
}

// ─────────────────────────────────────────────────────────────────────
// Contratos
// ─────────────────────────────────────────────────────────────────────
model Contrato {
  id                  String         @id @default(cuid())
  valor               Decimal        @db.Decimal(12, 2)
  dataInicio          DateTime
  dataFim             DateTime
  status              ContratoStatus @default(ATIVO)
  multaRescisoria     String?
  reajuste            String?        @default("IGP-M")
  observacoes         String?        @db.Text

  googleDriveFileId   String?
  googleDriveFileUrl  String?
  googleEventId       String?  // evento de aviso de vencimento

  clienteId String
  cliente   Cliente @relation(fields: [clienteId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([dataFim])
}

enum ContratoStatus {
  ATIVO
  ENCERRADO
  EM_RENOVACAO
  CANCELADO
}

// ─────────────────────────────────────────────────────────────────────
// Projetos (Kanban)
// ─────────────────────────────────────────────────────────────────────
model Projeto {
  id              String          @id @default(cuid())
  nome            String
  descricao       String?         @db.Text
  prioridade      Prioridade      @default(NORMAL)
  status          ProjetoStatus   @default(BRIEFING)
  dataEntrega     DateTime?

  googleDriveFolderId  String?
  googleDriveFolderUrl String?
  googleEventId        String?

  clienteId String?
  cliente   Cliente? @relation(fields: [clienteId], references: [id], onDelete: SetNull)

  tarefas Tarefa[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum ProjetoStatus {
  BRIEFING
  PRODUCAO
  REVISAO
  APROVACAO
  ENTREGUE
}

enum Prioridade {
  URGENTE
  ALTA
  NORMAL
  BAIXA
}

// ─────────────────────────────────────────────────────────────────────
// Tarefas
// ─────────────────────────────────────────────────────────────────────
model Tarefa {
  id              String      @id @default(cuid())
  titulo          String
  descricao       String?     @db.Text
  prioridade      Prioridade  @default(NORMAL)
  dataEntrega     DateTime?
  concluida       Boolean     @default(false)
  googleEventId   String?

  clienteId String?
  cliente   Cliente? @relation(fields: [clienteId], references: [id], onDelete: SetNull)

  projetoId String?
  projeto   Projeto? @relation(fields: [projetoId], references: [id], onDelete: SetNull)

  checklist CheckItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([dataEntrega])
}

model CheckItem {
  id        String  @id @default(cuid())
  texto     String
  concluido Boolean @default(false)
  ordem     Int     @default(0)

  tarefaId String
  tarefa   Tarefa @relation(fields: [tarefaId], references: [id], onDelete: Cascade)
}

// ─────────────────────────────────────────────────────────────────────
// Financeiro
// ─────────────────────────────────────────────────────────────────────
model Lancamento {
  id          String          @id @default(cuid())
  descricao   String
  valor       Decimal         @db.Decimal(12, 2)
  tipo        LancamentoTipo
  categoria   String?
  data        DateTime
  recorrente  Boolean         @default(false)
  entidade    Entidade        @default(PJ)

  clienteId String?
  cliente   Cliente? @relation(fields: [clienteId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([data])
  @@index([entidade])
}

enum LancamentoTipo {
  RECEITA
  DESPESA
}

enum Entidade {
  PJ
  PF
}

// ─────────────────────────────────────────────────────────────────────
// Drive — vínculos
// ─────────────────────────────────────────────────────────────────────
model DriveArquivo {
  id            String   @id @default(cuid())
  fileId        String
  nome          String
  mimeType      String?
  webViewLink   String?
  iconLink      String?
  isFolder      Boolean  @default(false)

  clienteId String?
  cliente   Cliente? @relation(fields: [clienteId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
}

// ─────────────────────────────────────────────────────────────────────
// Eventos da Agenda (espelho local opcional)
// ─────────────────────────────────────────────────────────────────────
model EventoAgenda {
  id             String           @id @default(cuid())
  googleEventId  String?          @unique
  titulo         String
  descricao      String?          @db.Text
  inicio         DateTime
  fim            DateTime
  tipo           EventoTipo       @default(REUNIAO)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum EventoTipo {
  REUNIAO
  PRAZO
  PUBLICACAO
  RENOVACAO
  OUTRO
}

// ─────────────────────────────────────────────────────────────────────
// Relatórios — Redes Sociais
// ─────────────────────────────────────────────────────────────────────
model MetricaRede {
  id            String   @id @default(cuid())
  rede          RedeSocial
  ano           Int
  mes           Int      // 1..12
  seguidores    Int      @default(0)
  alcance       Int      @default(0)
  impressoes    Int      @default(0)
  engajamento   Int      @default(0)
  posts         Int      @default(0)
  stories       Int      @default(0)
  reels         Int      @default(0)

  clienteId String
  cliente   Cliente @relation(fields: [clienteId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([clienteId, rede, ano, mes])
}

model MetaRede {
  id          String     @id @default(cuid())
  rede        RedeSocial
  metaSeguidores Int     @default(0)
  clienteId String
  cliente   Cliente @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  @@unique([clienteId, rede])
}

enum RedeSocial {
  INSTAGRAM
  FACEBOOK
  LINKEDIN
  TIKTOK
  YOUTUBE
}

// ─────────────────────────────────────────────────────────────────────
// Relatórios — SEO
// ─────────────────────────────────────────────────────────────────────
model MetricaSeo {
  id              String   @id @default(cuid())
  ano             Int
  mes             Int
  posicaoMedia    Float    @default(0)
  cliquesOrganicos Int     @default(0)
  impressoes      Int      @default(0)
  ctr             Float    @default(0)
  keywordsRanqueadas Int   @default(0)
  observacoes     String?  @db.Text

  clienteId String
  cliente   Cliente @relation(fields: [clienteId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([clienteId, ano, mes])
}

model SeoKeyword {
  id              String  @id @default(cuid())
  keyword         String
  posicaoAtual    Int     @default(0)
  posicaoAnterior Int     @default(0)
  volumeEstimado  Int     @default(0)
  urlRanqueada    String?

  clienteId String
  cliente   Cliente @relation(fields: [clienteId], references: [id], onDelete: Cascade)

  updatedAt DateTime @updatedAt
}

// ─────────────────────────────────────────────────────────────────────
// Relatórios — Tráfego Pago
// ─────────────────────────────────────────────────────────────────────
model CampanhaPaga {
  id              String          @id @default(cuid())
  ano             Int
  mes             Int
  plataforma      PlataformaAds
  nome            String
  investimento    Decimal         @db.Decimal(12, 2)
  impressoes      Int             @default(0)
  cliques         Int             @default(0)
  conversoes      Int             @default(0)
  cpa             Decimal         @default(0) @db.Decimal(12, 2)
  roas            Float           @default(0)
  cpm             Decimal         @default(0) @db.Decimal(12, 2)
  cpcMedio        Decimal         @default(0) @db.Decimal(12, 2)
  insights        String?         @db.Text

  clienteId String
  cliente   Cliente @relation(fields: [clienteId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clienteId, ano, mes])
}

enum PlataformaAds {
  META_ADS
  GOOGLE_ADS
  TIKTOK_ADS
  YOUTUBE_ADS
  LINKEDIN_ADS
}

// ─────────────────────────────────────────────────────────────────────
// Mentions — sistema de @ inline + backlinks automáticos
//
// Relação polimórfica leve: cada vez que um documento (Nota, Reuniao,
// Tarefa, Projeto, Cliente, Contrato) menciona outra entidade via @,
// uma linha é gravada aqui. Permite render de backlinks ("o que
// referencia este cliente?") sem varrer textos JSON.
//
// Sync acontece quando o documento é salvo:
//   1. extractMentions(blocks) varre blocos por inlineContent type=mention
//   2. syncMentions diff'a contra existing rows (insere novas, deleta órfãs)
//
// Não usamos FK porque source/target podem ser de tabelas diferentes;
// integridade é cuidada via cascade no source (quando documento morre,
// suas mentions outbound morrem junto via job/trigger). Mentions inbound
// para entidade deletada ficam órfãs e são filtradas no fetch.
// ─────────────────────────────────────────────────────────────────────
model Mention {
  id String @id @default(cuid())

  // De onde a menção foi feita (documento que contém o @)
  sourceType MentionEntity
  sourceId   String
  // Trecho de contexto opcional (ex: 80 chars ao redor do @) para preview
  context    String? @db.Text

  // O que foi mencionado
  targetType MentionEntity
  targetId   String

  createdAt DateTime @default(now())

  @@unique([sourceType, sourceId, targetType, targetId])
  @@index([targetType, targetId])
  @@index([sourceType, sourceId])
}

enum MentionEntity {
  CLIENTE
  REUNIAO
  POST
  PROJETO
  TAREFA
  CONTRATO
  NOTA
}

// ─────────────────────────────────────────────────────────────────────
// Templates — esqueletos pré-prontos pra Notas, Reuniões e Briefings
//
// Built-ins (criadoPor = null) são populados via seed e vêm com o
// sistema. Usuários podem criar próprios templates ou clonar os
// built-ins. Variáveis no formato {{var}} são expandidas no momento
// da instanciação (ver src/lib/template-variables.ts).
// ─────────────────────────────────────────────────────────────────────
model Template {
  id            String       @id @default(cuid())
  nome          String
  descricao     String?      @db.Text

  tipo          TemplateTipo
  categoria     String?      // "Onboarding", "Operacional", "Estratégia"
  icone         String?      // emoji ou nome lucide ("FileText", "Mic", "📋")
  cor           String?      // hex pra badge

  conteudo      String       @db.Text  // JSON BlockNote serializado

  // null = template do sistema (built-in via seed). Vincular a User permite
  // saber quem criou e (no futuro) compartilhamento granular.
  criadoPor     String?
  // Sem FK explícita pra simplificar (User não tem relacionamento reverso
  // que precise rastrear templates). Cleanup manual se um user for excluído.

  compartilhado Boolean      @default(true)
  quantidadeUsos Int         @default(0)
  ultimoUso     DateTime?

  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@index([tipo, compartilhado])
  @@index([criadoPor])
}

enum TemplateTipo {
  NOTA
  REUNIAO
  BRIEFING
  TAREFA
  PROJETO
}

// ─────────────────────────────────────────────────────────────────────
// Notificações — alertas in-app (sininho + dashboard)
//
// Geração on-demand: quando user abre o dashboard ou o sininho, o backend
// chama `gerarNotificacoes(userId)` que varre regras (contratos vencendo,
// tarefas atrasadas, etc) e cria/atualiza linhas idempotentemente.
//
// Idempotência: cada notificação tem uma `chave` única por (user, tipo,
// entidade, dia), pra mesma regra não duplicar entre runs.
// ─────────────────────────────────────────────────────────────────────
model Notificacao {
  id          String           @id @default(cuid())
  tipo        TipoNotificacao
  titulo      String
  descricao   String?
  href        String?          // rota pra navegar ao clicar

  // Contexto polimórfico — entidade que disparou a notificação
  entidadeTipo String?         // "CONTRATO", "TAREFA", "REUNIAO", etc
  entidadeId   String?

  // Chave de idempotência: combina tipo + entidade + dia (YYYY-MM-DD).
  // Permite "contrato X vence em 30 dias" gerar 1 notificação por dia,
  // mas não duplicar se o mesmo dia ainda continuar.
  chave        String

  userId    String
  user      User @relation(fields: [userId], references: [id], onDelete: Cascade)

  lida      Boolean   @default(false)
  lidaEm    DateTime?

  // Quando true, já mandamos email pro user — evita dispatch duplicado
  // mesmo se gerarNotificacoes rodar várias vezes no dia (a chave já é
  // idempotente, mas reforço extra por segurança).
  enviadaPorEmail Boolean @default(false)

  createdAt DateTime  @default(now())

  @@unique([userId, chave])
  @@index([userId, lida, createdAt])
  @@index([entidadeTipo, entidadeId])
}

enum TipoNotificacao {
  CONTRATO_VENCENDO
  ACTION_ITEM_ATRASADO
  TAREFA_ATRASADA
  REUNIAO_HOJE
  POST_HOJE
  PROPOSTA_VISTA
  PROPOSTA_ACEITA
  PROPOSTA_RECUSADA
  SISTEMA
}

// ─────────────────────────────────────────────────────────────────────
// Propostas comerciais — geradas como link público pro cliente
//
// Numeração: `YYYY-NNN` (ex: 2026-001), incrementa por ano via lógica
// no POST (não FK pra evitar lock; volume baixo).
//
// Cada seção é JSON BlockNote serializado. PDF é gerado on-demand via
// @react-pdf/renderer.
//
// Share: shareToken inline (não usa PublicShare). Cliente acessa
// `/p/proposta/{token}`. Aceite/recusa registrados via POST sem auth
// (autenticado pelo token).
// ─────────────────────────────────────────────────────────────────────
model Proposta {
  id              String         @id @default(cuid())
  numero          String         @unique  // "2026-001"
  titulo          String

  // Cliente — opcional (pode mandar proposta pra prospect sem cliente cadastrado)
  clienteId       String?
  cliente         Cliente?       @relation(fields: [clienteId], references: [id], onDelete: SetNull)
  clienteNome     String         // snapshot — preserva mesmo se cliente for editado/deletado
  clienteEmail    String?

  // Conteúdo (cada um JSON BlockNote)
  capa            String?        @db.Text
  diagnostico     String?        @db.Text
  objetivo        String?        @db.Text
  escopo          String?        @db.Text
  cronograma      String?        @db.Text
  investimento    String?        @db.Text
  proximosPassos  String?        @db.Text
  termos          String?        @db.Text

  // Comercial
  valorMensal     Decimal?       @db.Decimal(12, 2)
  valorTotal      Decimal?       @db.Decimal(12, 2)
  duracaoMeses    Int?
  validadeDias    Int            @default(30)

  // Customização visual
  logoUrl         String?        @db.Text   // dataURL ou URL externa
  corPrimaria     String?        // hex (#7E30E1 default no front)

  // Status
  status          PropostaStatus @default(RASCUNHO)
  enviadaEm       DateTime?
  vistaEm         DateTime?
  aceitaEm        DateTime?
  recusadaEm      DateTime?
  recusaMotivo    String?        @db.Text

  // Share público
  shareToken      String?        @unique
  shareExpiraEm   DateTime?
  shareSenha      String?        // bcrypt hash, opcional
  shareViews      Int            @default(0)

  // Aceite digital
  aceiteIp        String?
  aceiteUa        String?

  // Vinculo opcional a um Lead (pipeline pré-cliente)
  leadId          String?
  lead            Lead?          @relation(fields: [leadId], references: [id], onDelete: SetNull)

  // Audit
  criadoPor       String
  user            User           @relation(fields: [criadoPor], references: [id], onDelete: Cascade)

  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@index([clienteId, status])
  @@index([status, updatedAt])
  @@index([shareToken])
  @@index([leadId])
}

enum PropostaStatus {
  RASCUNHO
  ENVIADA
  VISTA
  ACEITA
  RECUSADA
  EXPIRADA
}

// ─────────────────────────────────────────────────────────────────────
// Compartilhamento público genérico — gera link read-only com expiração
// pra Notas, Briefings, Relatórios. Polimórfico via entidadeTipo/Id.
//
// Propostas têm seu próprio share inline (acima) porque tem fluxo
// específico (aceite, recusa). Esse model serve pra conteúdo de
// leitura simples.
// ─────────────────────────────────────────────────────────────────────
model PublicShare {
  id              String         @id @default(cuid())
  token           String         @unique
  entidadeTipo    ShareEntidade
  entidadeId      String

  expiraEm        DateTime?      // null = nunca expira
  senha           String?        // bcrypt hash opcional

  views           Int            @default(0)
  primeiroAcesso  DateTime?
  ultimoAcesso    DateTime?

  podeBaixarPdf   Boolean        @default(true)

  criadoPor       String
  user            User           @relation(fields: [criadoPor], references: [id], onDelete: Cascade)

  createdAt       DateTime       @default(now())

  @@index([entidadeTipo, entidadeId])
}

enum ShareEntidade {
  NOTA
  BRIEFING
  REUNIAO
  RELATORIO
  MANUAL_SECAO
}

// ─────────────────────────────────────────────────────────────────────
// Lead — pipeline pré-cliente (oportunidade comercial estilo HubSpot)
//
// Fluxo: lead chega → atravessa estágios → quando fecha "GANHO",
// converte em Cliente (entidade já existente). O campo `clienteId` é
// populado nessa conversão e cria a ligação histórica.
//
// Propostas podem ser vinculadas a um lead via `leadId` (ver Proposta).
// ─────────────────────────────────────────────────────────────────────
model Lead {
  id                    String     @id @default(cuid())

  // Identidade
  empresa               String
  contatoNome           String?
  contatoEmail          String?
  contatoTelefone       String?
  segmento              String?    // "Restaurante", "E-commerce", "SaaS B2B"
  porte                 LeadPorte?
  origem                String?    // texto livre: "Indicação Pipeline", "Google", "Evento X"

  // Pipeline
  status                LeadStatus @default(NOVO)
  prioridade            Prioridade @default(NORMAL)

  // Comercial estimado
  valorEstimadoMensal   Decimal?   @db.Decimal(12, 2)
  duracaoEstimadaMeses  Int?

  // Contexto rico
  notas                 String?    @db.Text  // JSON BlockNote
  proximaAcao           String?    // "Ligar quinta", "Mandar caso A"
  proximaAcaoEm         DateTime?

  // Tags livres
  tags                  String[]

  // Lead score 0-100. `scoreManual` (se preenchido) sobrescreve o cálculo.
  score                 Int        @default(0)
  scoreManual           Int?

  // Conversão
  clienteId             String?    @unique // null até converter
  cliente               Cliente?   @relation(fields: [clienteId], references: [id], onDelete: SetNull)
  convertidoEm          DateTime?
  motivoPerdido         String?    @db.Text

  // Propostas vinculadas (1:N)
  propostas             Proposta[]

  // Responsável
  responsavel           String
  user                  User       @relation(fields: [responsavel], references: [id], onDelete: Cascade)

  createdAt             DateTime   @default(now())
  updatedAt             DateTime   @updatedAt

  @@index([status, responsavel])
  @@index([clienteId])
  @@index([status, updatedAt])
}

enum LeadStatus {
  NOVO
  QUALIFICACAO
  DIAGNOSTICO
  PROPOSTA_ENVIADA
  NEGOCIACAO
  GANHO
  PERDIDO
}

enum LeadPorte {
  SMALL    // micro/pequena
  MID      // média
  LARGE    // grande
}

// ─────────────────────────────────────────────────────────────────────
// Conteúdo SAL — planejamento de marketing da própria agência
//
// Modulo dedicado, separado de Post (editorial dos clientes). Cobre
// 9 formatos (redes, newsletter, blog, ad). Status reusa PostStatus
// pra manter consistência de workflow.
//
// `pilar` é texto livre (não enum) pra Marcelo experimentar pilares
// editoriais conforme estratégia evolui.
// ─────────────────────────────────────────────────────────────────────
model ConteudoSAL {
  id              String       @id @default(cuid())
  titulo          String
  copy            String?      @db.Text  // JSON BlockNote
  briefing        String?      @db.Text  // contexto/motivação
  formato         FormatoSAL
  status          PostStatus   @default(RASCUNHO)
  pilar           String?      // "Autoridade", "Educacional", etc — livre
  dataPublicacao  DateTime
  url             String?      // link pra peça publicada
  googleEventId   String?      // sync com Agenda quando agendado

  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@index([dataPublicacao])
  @@index([status, pilar])
}

enum FormatoSAL {
  INSTAGRAM_FEED
  INSTAGRAM_STORIES
  INSTAGRAM_REELS
  LINKEDIN
  TIKTOK
  YOUTUBE
  NEWSLETTER
  BLOG_POST
  AD_CREATIVE
}

// ─────────────────────────────────────────────────────────────────────
// Integração Sheets — vínculo manual com planilha pública do Google
//
// Marcelo torna a planilha pública (qualquer pessoa com link → leitor),
// cola URL aqui, sistema lê via /export?format=csv e popula as métricas
// no banco. Não usa OAuth — planilha PRECISA ser pública (URL share).
//
// Sincronização é manual ("Sincronizar agora") — sem cron no MVP.
// `ultimaSync` registra última execução, `totalLinhas` mostra contador
// pra Marcelo conferir se a importação bateu com o que viu na planilha.
//
// `fonte` define qual destino: REDES → MetricaRede, SEO → MetricaSeo,
// TRAFEGO → CampanhaPaga. Cada destino tem mapeador próprio em
// lib/relatorio-mapeadores.ts.
// ─────────────────────────────────────────────────────────────────────
model IntegracaoSheets {
  id           String           @id @default(cuid())
  clienteId    String
  cliente      Cliente          @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  fonte        FonteRelatorio
  sheetUrl     String           @db.Text   // URL pública (qualquer formato Google aceita)
  rotulo       String?          // ex: "Meta Ads — Q1 2026"
  ultimaSync   DateTime?
  totalLinhas  Int              @default(0)
  ultimoErro   String?          @db.Text   // mensagem se a última sync falhou
  ativo        Boolean          @default(true)
  criadoPor    String

  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  @@index([clienteId, fonte])
}

enum FonteRelatorio {
  REDES
  SEO
  TRAFEGO
}

// ─────────────────────────────────────────────────────────────────────
// Manual SAL — playbook operacional + brand book interno
//
// Wiki interno organizado em 2 categorias (PLAYBOOK e MARCA) com
// hierarquia opcional (seção pode ter filhas) e conteúdo rico em
// BlockNote. Substitui o "Notion interno" que muitas agências mantêm
// em ferramentas externas.
//
// Slug é único por tipo (pra URL `/manual/PLAYBOOK/onboarding-cliente`).
// Pai/filhas via self-relation. Reordenação manual via `ordem` (int).
// ─────────────────────────────────────────────────────────────────────
model DocSecao {
  id          String     @id @default(cuid())
  tipo        DocTipo
  titulo      String
  slug        String                    // único por tipo
  conteudo    String     @default("") @db.Text  // JSON BlockNote
  icone       String?                   // emoji ou nome lucide (ex: "🏢", "FileText")
  ordem       Int        @default(0)
  publicada   Boolean    @default(true) // false = rascunho (UI esconde da sidebar)

  // Hierarquia opcional (1 nível típico: pai = categoria temática, filhas = sub-tópicos)
  parentId    String?
  parent      DocSecao?  @relation("DocHierarquia", fields: [parentId], references: [id], onDelete: SetNull)
  filhas      DocSecao[] @relation("DocHierarquia")

  criadoPor   String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@unique([tipo, slug])
  @@index([tipo, ordem])
  @@index([parentId])
}

enum DocTipo {
  PLAYBOOK
  MARCA
}

// ─────────────────────────────────────────────────────────────────────
// Configuração global do sistema — pattern singleton (id fixo = "default").
//
// Vai crescendo conforme aparecem decisões que precisam ser persistidas
// fora de env vars (porque user quer editar pela UI sem deploy). Hoje
// só guarda preferências do onboarding de cliente; pode-se adicionar
// outros campos depois.
//
// Convenção: sempre upsert via `where: { id: "default" }`. UI lê/escreve
// a row única. Migration cria a linha via seed se não existir.
// ─────────────────────────────────────────────────────────────────────
model Configuracao {
  id String @id @default("default")

  // ── Onboarding: onde criar pastas dos clientes ──────────────────
  // Tipo:
  //  - "meu_drive" → cria em Meu Drive pessoal do user logado
  //  - "shared_drive" → cria na raiz do Shared Drive identificado por `onboardingDriveId`
  //  - "pasta" → cria dentro da pasta `onboardingDriveParentId` (em qualquer drive)
  onboardingDestinoTipo  String  @default("shared_drive")
  onboardingDriveId      String?           // ID do Shared Drive selecionado
  onboardingDriveNome    String?           // nome cacheado pra UI (não fonte da verdade)
  onboardingParentId     String?           // ID de pasta (se destino="pasta")
  onboardingParentNome   String?           // nome cacheado pra UI

  atualizadoEm DateTime @updatedAt
  atualizadoPor String?
}
